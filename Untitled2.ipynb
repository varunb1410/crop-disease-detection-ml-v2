    "import tensorflow as tf\n",
    "\n",
    "# Load existing model\n",
    "model = tf.keras.models.load_model(\n",
    "    \"model.h5\",\n",
    "    compile=False\n",
    ")\n",
    "\n",
    "# Save again in legacy H5 format\n",
    "model.save(\"final_model.h5\", save_format=\"h5\")\n",
    "\n",
    "print(\"Model converted successfully!\")"
   ]
